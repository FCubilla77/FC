<odoo>
    <data>
        <record id="view_payment_term_form_l10n_py" model="ir.ui.view">
            <field name="name">account.payment.term.form.l10n.py</field>
            <field name="model">account.payment.term</field>
            <field name="inherit_id" ref="account.view_payment_term_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[field[@name='company_id']]" position="after">
                    <group string="Localización Paraguay">
                        <field name="l10n_py_condicion" string="Condición (Contado/Crédito)"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
