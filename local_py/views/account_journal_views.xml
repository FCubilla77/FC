<odoo>
    <data>
        <record id="view_account_journal_form_l10n_py" model="ir.ui.view">
            <field name="name">account.journal.form.l10n.py</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <group string="Localización Paraguay" invisible="type != 'sale'">
                        <field name="l10n_py_timbrado" string="Timbrado"/>
                        <field name="l10n_py_nro_documento" string="Nro. Documento" placeholder="000000000-0"/>
                        <field name="l10n_py_venc_timbrado" string="Venc. Timbrado"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
