<odoo>
    <data>
        <record id="view_local_py_asientos_fiscales_list" model="ir.ui.view">
            <field name="name">local_py.asientos_fiscales.list</field>
            <field name="model">account.move</field>
            <field name="arch" type="xml">
                <list string="Asientos Fiscales" create="false"
                      default_order="l10n_py_nro_fiscal desc, date desc, name desc">
                    <field name="l10n_py_nro_fiscal" readonly="1"/>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="move_type"/>
                    <field name="journal_id"/>
                    <field name="partner_id" optional="show"/>
                    <field name="amount_total_signed" string="Total"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'posted'"/>
                </list>
            </field>
        </record>

        <record id="action_local_py_asientos_fiscales" model="ir.actions.act_window">
            <field name="name">Asientos Fiscales</field>
            <field name="res_model">account.move</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_local_py_asientos_fiscales_list"/>
            <field name="search_view_id" ref="account.view_account_move_filter"/>
        </record>

        <menuitem id="menu_local_py_asientos_fiscales"
                  name="Asientos Fiscales"
                  parent="menu_l10n_py_localizacion"
                  action="action_local_py_asientos_fiscales"
                  groups="account.group_account_manager"
                  sequence="30"/>
    </data>
</odoo>
