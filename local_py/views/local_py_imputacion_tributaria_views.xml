<odoo>
    <data>
        <record id="view_local_py_imputacion_tributaria_list" model="ir.ui.view">
            <field name="name">local_py.imputacion_tributaria.list</field>
            <field name="model">local_py.imputacion_tributaria</field>
            <field name="arch" type="xml">
                <list string="Imputación Tributaria">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_local_py_imputacion_tributaria_form" model="ir.ui.view">
            <field name="name">local_py.imputacion_tributaria.form</field>
            <field name="model">local_py.imputacion_tributaria</field>
            <field name="arch" type="xml">
                <form string="Imputación Tributaria">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_local_py_imputacion_tributaria" model="ir.actions.act_window">
            <field name="name">Imputación Tributaria</field>
            <field name="res_model">local_py.imputacion_tributaria</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_local_py_imputacion_tributaria"
                  name="Imputación Tributaria"
                  parent="menu_l10n_py_localizacion"
                  action="action_local_py_imputacion_tributaria"
                  sequence="20"/>
    </data>
</odoo>
