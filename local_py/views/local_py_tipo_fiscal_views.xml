<odoo>
    <data>
        <record id="view_local_py_tipo_fiscal_list" model="ir.ui.view">
            <field name="name">local_py.tipo_fiscal.list</field>
            <field name="model">local_py.tipo_fiscal</field>
            <field name="arch" type="xml">
                <list string="Tipos de Documentos Fiscales">
                    <field name="sequence" widget="handle"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_local_py_tipo_fiscal_form" model="ir.ui.view">
            <field name="name">local_py.tipo_fiscal.form</field>
            <field name="model">local_py.tipo_fiscal</field>
            <field name="arch" type="xml">
                <form string="Tipos de Documentos Fiscales">
                    <sheet>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_local_py_tipo_fiscal" model="ir.actions.act_window">
            <field name="name">Tipos de Documentos Fiscales</field>
            <field name="res_model">local_py.tipo_fiscal</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_l10n_py_localizacion"
                  name="Localización Paraguay"
                  parent="account.menu_finance"
                  sequence="90"/>

        <menuitem id="menu_local_py_datos_maestros"
                  name="Datos Maestros"
                  parent="menu_l10n_py_localizacion"
                  sequence="10"/>

        <menuitem id="menu_local_py_configuraciones"
                  name="Configuraciones"
                  parent="menu_l10n_py_localizacion"
                  sequence="20"/>

        <menuitem id="menu_local_py_procesos"
                  name="Procesos"
                  parent="menu_l10n_py_localizacion"
                  sequence="30"/>

        <menuitem id="menu_local_py_tipo_fiscal"
                  name="Tipos de Documentos Fiscales"
                  parent="menu_local_py_datos_maestros"
                  action="action_local_py_tipo_fiscal"
                  sequence="40"/>
    </data>
</odoo>
