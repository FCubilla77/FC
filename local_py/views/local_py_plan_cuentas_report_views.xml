<odoo>
    <data>
        <record id="view_local_py_plan_cuentas_report_list" model="ir.ui.view">
            <field name="name">local_py.plan_cuentas.report.list</field>
            <field name="model">local_py.plan_cuentas.report</field>
            <field name="arch" type="xml">
                <list string="Plan de Cuentas" create="false" edit="false" delete="false"
                      decoration-bf="tipo == 'title'">
                    <header>
                        <button name="action_manual_refresh" type="object" string="Actualizar" class="btn-secondary"/>
                    </header>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="tipo"/>
                    <field name="nivel"/>
                    <field name="account_type"/>
                    <field name="group_name" optional="show"/>
                    <button name="action_open_account" type="object" string="Abrir cuenta"
                            icon="fa-external-link" invisible="tipo != 'imputable'"/>
                </list>
            </field>
        </record>

        <record id="view_local_py_plan_cuentas_report_search" model="ir.ui.view">
            <field name="name">local_py.plan_cuentas.report.search</field>
            <field name="model">local_py.plan_cuentas.report</field>
            <field name="arch" type="xml">
                <search string="Buscar en Plan de Cuentas">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="nivel_1"/>
                    <filter string="Títulos" name="filter_title" domain="[('tipo', '=', 'title')]"/>
                    <filter string="Imputables" name="filter_imputable" domain="[('tipo', '=', 'imputable')]"/>
                    <separator/>
                    <filter string="1 - Activo" name="filter_nivel_1_1" domain="[('nivel_1', '=', '1')]"/>
                    <filter string="2 - Pasivo" name="filter_nivel_1_2" domain="[('nivel_1', '=', '2')]"/>
                    <filter string="3 - Patrimonio Neto" name="filter_nivel_1_3" domain="[('nivel_1', '=', '3')]"/>
                    <filter string="4 - Ingresos Operativos" name="filter_nivel_1_4" domain="[('nivel_1', '=', '4')]"/>
                    <filter string="5 - Costos Operativos" name="filter_nivel_1_5" domain="[('nivel_1', '=', '5')]"/>
                    <filter string="6 - Otros Ingresos" name="filter_nivel_1_6" domain="[('nivel_1', '=', '6')]"/>
                    <filter string="7 - Gastos" name="filter_nivel_1_7" domain="[('nivel_1', '=', '7')]"/>
                    <separator/>
                    <filter string="Nivel 1" name="group_nivel_1" context="{'group_by': 'nivel_1'}"/>
                    <filter string="Tipo" name="group_tipo" context="{'group_by': 'tipo'}"/>
                </search>
            </field>
        </record>

        <record id="action_local_py_plan_cuentas_report" model="ir.actions.act_window">
            <field name="name">Plan de Cuentas</field>
            <field name="res_model">local_py.plan_cuentas.report</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_local_py_plan_cuentas_report_list"/>
            <field name="search_view_id" ref="view_local_py_plan_cuentas_report_search"/>
        </record>

        <menuitem id="menu_local_py_plan_cuentas_report"
                  name="Plan de Cuentas"
                  parent="account.menu_finance_reports"
                  action="action_local_py_plan_cuentas_report"
                  sequence="15"/>

        <!-- Acceso directo al Plan de Cuentas estándar de Odoo (account.account),
             disponible en Community; se ubica en el menú propio "Localización
             Paraguay" para no depender de los permisos más restrictivos de
             Contabilidad > Configuración. -->
        <menuitem id="menu_l10n_py_chart_of_accounts"
                  name="Plan de Cuentas (editar cuentas)"
                  parent="local_py.menu_l10n_py_localizacion"
                  action="account.action_account_form"
                  sequence="20"/>
    </data>
</odoo>
