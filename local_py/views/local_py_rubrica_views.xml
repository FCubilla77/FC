<odoo>
    <data>
        <record id="view_local_py_rubrica_form" model="ir.ui.view">
            <field name="name">local_py.rubrica.form</field>
            <field name="model">local_py.rubrica</field>
            <field name="arch" type="xml">
                <form string="Rúbrica">
                    <header>
                        <button name="action_confirm" type="object" string="Confirmar"
                                class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_draft" type="object" string="Restablecer a Borrador"
                                invisible="state != 'confirmed'"
                                groups="account.group_account_manager"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="company_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                                <field name="idrubrica" readonly="state != 'draft'"/>
                                <field name="fecha" readonly="state != 'draft'"/>
                                <field name="uso" readonly="state != 'draft'"/>
                                <field name="cantidad_hojas" readonly="state != 'draft'"/>
                                <field name="nro_entrada" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="fecha_entrada" readonly="state != 'draft'"/>
                                <field name="numero_inicial" readonly="state != 'draft'"/>
                                <field name="numero_final" readonly="state != 'draft'"/>
                                <field name="utilizado_hasta" readonly="1"/>
                                <field name="imagen" filename="imagen_filename" readonly="state != 'draft'"/>
                                <field name="imagen_filename" invisible="1"/>
                                <field name="primera_hoja" filename="primera_hoja_filename" readonly="state != 'draft'"/>
                                <field name="primera_hoja_filename" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_local_py_rubrica_list" model="ir.ui.view">
            <field name="name">local_py.rubrica.list</field>
            <field name="model">local_py.rubrica</field>
            <field name="arch" type="xml">
                <list string="Rúbricas">
                    <field name="company_id"/>
                    <field name="idrubrica"/>
                    <field name="fecha"/>
                    <field name="uso"/>
                    <field name="numero_inicial"/>
                    <field name="numero_final"/>
                    <field name="utilizado_hasta"/>
                    <field name="state" widget="badge" decoration-success="state == 'confirmed'" decoration-muted="state == 'draft'"/>
                </list>
            </field>
        </record>

        <record id="view_local_py_rubrica_search" model="ir.ui.view">
            <field name="name">local_py.rubrica.search</field>
            <field name="model">local_py.rubrica</field>
            <field name="arch" type="xml">
                <search string="Buscar Rúbrica">
                    <field name="idrubrica"/>
                    <field name="nro_entrada"/>
                    <field name="company_id"/>
                    <field name="uso"/>
                    <separator/>
                    <filter string="Borrador" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Confirmado" name="filter_confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <separator/>
                    <filter string="Compañía" name="group_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Uso" name="group_uso" context="{'group_by': 'uso'}"/>
                </search>
            </field>
        </record>

        <record id="action_local_py_rubrica" model="ir.actions.act_window">
            <field name="name">Rubricas</field>
            <field name="res_model">local_py.rubrica</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_local_py_rubrica"
                  name="Rubricas"
                  parent="menu_local_py_procesos"
                  action="action_local_py_rubrica"
                  groups="account.group_account_manager"
                  sequence="40"/>
    </data>
</odoo>
