<odoo>
    <data>
        <record id="view_local_py_city_list" model="ir.ui.view">
            <field name="name">res.city.list.local_py</field>
            <field name="model">res.city</field>
            <field name="inherit_id" ref="base_address_extended.view_city_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='zipcode']" position="replace">
                    <field name="code"/>
                </xpath>
                <xpath expr="//field[@name='state_id']" position="before">
                    <field name="district_id"/>
                </xpath>
            </field>
        </record>

        <menuitem id="menu_local_py_city"
                  name="Ciudades"
                  parent="menu_l10n_py_localizacion"
                  action="base_address_extended.action_res_city_tree"
                  sequence="35"/>
    </data>
</odoo>
