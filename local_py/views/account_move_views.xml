<odoo>
    <data>
        <record id="view_move_form_l10n_py" model="ir.ui.view">
            <field name="name">account.move.form.l10n.py</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='journal_id']" position="after">
                    <field name="l10n_py_timbrado"/>
                    <field name="l10n_py_nro_documento" placeholder="000000000-0"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
