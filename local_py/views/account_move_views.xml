<odoo>
    <data>
        <record id="view_move_form_l10n_py" model="ir.ui.view">
            <field name="name">account.move.form.l10n.py</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <!--
                    journal_id puede aparecer más de una vez en el documento completo
                    del formulario. Se excluyen coincidencias dentro de <tree>/<notebook>
                    y se toma la ÚLTIMA coincidencia restante (el selector visible del
                    encabezado).

                    En vez de insertar el grupo nuevo DENTRO de la columna angosta donde
                    vive journal_id (lo que comprimía el valor letra por letra), se ubica
                    DESPUÉS del grupo contenedor más externo de esa columna (ancestor::group
                    en su posición más alta), de forma que ocupe el ancho completo del
                    formulario, debajo de todo el bloque de cabecera.
                -->
                <xpath expr="(//field[@name='journal_id'][not(ancestor::tree) and not(ancestor::notebook)])[last()]/ancestor::group[last()]" position="after">
                    <group string="Localización Paraguay" invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')">
                        <field name="l10n_py_timbrado"
                               string="Timbrado"
                               options="{'enable_formatting': False}"
                               readonly="move_type in ('out_invoice', 'out_refund') or state != 'draft'"/>
                        <field name="l10n_py_nro_documento"
                               string="Nro. Documento"
                               placeholder="000-000-0000000"
                               readonly="move_type in ('out_invoice', 'out_refund') or state != 'draft'"/>
                        <field name="local_py_tipo_fiscal_id"
                               string="Tipo Fiscal"
                               readonly="move_type in ('out_invoice', 'out_refund') or state != 'draft'"/>
                        <field name="l10n_py_imputacion_tributaria_ids"
                               string="Imputación Tributaria"
                               widget="many2many_tags"/>
                        <field name="reversed_entry_id"
                               string="Comprobante Asociado"
                               invisible="move_type not in ('out_refund', 'in_refund')"
                               readonly="state != 'draft'"
                               domain="[('move_type', '=', 'out_invoice' if move_type == 'out_refund' else 'in_invoice'), ('state', '=', 'posted')]"/>
                        <field name="l10n_py_nro_documento_asociado"
                               string="Nro. Documento Comprobante Asociado"
                               invisible="move_type not in ('out_refund', 'in_refund')"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="view_move_tree_l10n_py" model="ir.ui.view">
            <field name="name">account.move.list.l10n.py</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='journal_id']" position="after">
                    <field name="l10n_py_nro_fiscal" string="Nro. Fiscal" optional="show"
                           readonly="1" groups="account.group_account_manager"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
